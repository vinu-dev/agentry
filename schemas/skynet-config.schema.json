{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vinu-dev/skynet-agentry/schemas/skynet-config.schema.json",
  "title": "Skynet Agentry Target Configuration",
  "description": "Schema for .skynet/config.yml in target repositories. Loaded and enforced by `skynet doctor` and the orchestrator. Companion to COMPATIBILITY-SPEC.md (v0.0a-2 revised).",
  "type": "object",
  "required": [
    "skynet_version",
    "project",
    "test",
    "auto_merge",
    "agents",
    "budget",
    "notification"
  ],
  "additionalProperties": false,

  "properties": {
    "skynet_version": {
      "type": "string",
      "description": "PEP 440 version specifier for the framework version range this target supports.",
      "minLength": 1,
      "examples": [">=0.4,<1.0", "==0.4.2", ">=0.5"]
    },

    "project": {
      "type": "object",
      "required": ["name", "languages"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "languages": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "description": { "type": "string", "default": "" }
      }
    },

    "providers": {
      "type": "object",
      "description": "Custom provider declarations. Built-in providers (anthropic, openai, codex_cli) require no declaration. Custom providers are referenced by their key throughout the config.",
      "additionalProperties": { "$ref": "#/$defs/custom_provider" }
    },

    "defaults": {
      "type": "object",
      "description": "Defaults inherited by every role unless overridden per-role.",
      "additionalProperties": false,
      "properties": {
        "primary": { "$ref": "#/$defs/model_ref" },
        "fallbacks": {
          "type": "array",
          "items": { "$ref": "#/$defs/model_ref" }
        },
        "prompt_extras": { "type": "string" },
        "tool_allowlist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "max_tokens_per_call": { "type": "integer", "minimum": 1000 },
        "timeout_seconds": { "type": "integer", "minimum": 10 },
        "max_retries": { "type": "integer", "minimum": 1, "maximum": 10 },
        "on_rate_limit": { "$ref": "#/$defs/on_rate_limit" },
        "on_capability_exceeded": { "$ref": "#/$defs/on_capability_exceeded" },
        "on_stall": { "$ref": "#/$defs/on_stall" }
      }
    },

    "build": {
      "type": "object",
      "description": "Build commands. Required only if release.enabled is true.",
      "additionalProperties": { "type": "string" },
      "properties": {
        "default": { "type": "string" },
        "prod": { "type": "string" }
      }
    },

    "test": {
      "type": "object",
      "description": "Test matrix. `unit` is the minimum required.",
      "required": ["unit"],
      "additionalProperties": { "type": "string" },
      "properties": {
        "unit": { "type": "string", "minLength": 1 },
        "integration": { "type": "string" },
        "contract": { "type": "string" },
        "e2e": { "type": "string" },
        "lint": { "type": "string" },
        "format": { "type": "string" }
      }
    },

    "hardware": {
      "type": "object",
      "description": "Hardware test rigs. In v0, enabled MUST be false.",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "rigs": {
          "type": "array",
          "items": { "$ref": "#/$defs/rig" },
          "default": []
        }
      }
    },

    "release": {
      "type": "object",
      "description": "Release configuration. In v0, strategy MUST be 'none'.",
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["none", "github-release", "yocto-swu"],
          "default": "none"
        },
        "trigger": { "type": "string", "default": "milestone" },
        "artifact_glob": { "type": "string" },
        "signing_key_env": { "type": "string" }
      }
    },

    "auto_merge": {
      "type": "object",
      "description": "Path-policy table for auto-merge. See COMPATIBILITY-SPEC.md §11.",
      "required": ["default_policy"],
      "additionalProperties": false,
      "properties": {
        "default_policy": { "$ref": "#/$defs/policy" },
        "hold_hours": {
          "type": "integer",
          "minimum": 1,
          "maximum": 168,
          "default": 24
        },
        "path_policies": {
          "type": "object",
          "patternProperties": {
            "^.+$": { "$ref": "#/$defs/policy" }
          },
          "additionalProperties": false
        }
      }
    },

    "agents": {
      "type": "object",
      "description": "Agent roster. Implementer and Reviewer MUST resolve to different vendors (enforced semantically by skynet doctor). All seven roles are recognized; minimum required: researcher, architect, implementer, tester, pr_author, reviewer.",
      "required": [
        "researcher",
        "architect",
        "implementer",
        "tester",
        "pr_author",
        "reviewer"
      ],
      "additionalProperties": false,
      "properties": {
        "researcher": { "$ref": "#/$defs/agent_researcher" },
        "architect": { "$ref": "#/$defs/agent_basic" },
        "implementer": { "$ref": "#/$defs/agent_basic" },
        "tester": { "$ref": "#/$defs/agent_basic" },
        "pr_author": { "$ref": "#/$defs/agent_basic" },
        "reviewer": { "$ref": "#/$defs/agent_basic" },
        "release": { "$ref": "#/$defs/agent_release" }
      }
    },

    "budget": {
      "type": "object",
      "description": "Budget boundary — daily spend, per-task tokens, retry cap, concurrency cap.",
      "required": [
        "daily_dollars",
        "per_task_tokens",
        "retry_cap",
        "concurrent_tasks"
      ],
      "additionalProperties": false,
      "properties": {
        "daily_dollars": { "type": "number", "exclusiveMinimum": 0 },
        "per_task_tokens": { "type": "integer", "minimum": 1000 },
        "retry_cap": { "type": "integer", "minimum": 1, "maximum": 10, "default": 3 },
        "concurrent_tasks": { "type": "integer", "minimum": 1, "maximum": 10, "default": 2 }
      }
    },

    "notification": {
      "type": "object",
      "required": ["channel", "webhook_env"],
      "additionalProperties": false,
      "properties": {
        "channel": {
          "type": "string",
          "enum": ["discord", "telegram", "email"],
          "default": "discord"
        },
        "webhook_env": { "type": "string", "minLength": 1 }
      }
    },

    "traceability": {
      "type": "object",
      "description": "Optional. Required for the full compatibility level.",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "check_command": { "type": "string" },
        "required_for_paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "if": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
      "then": { "required": ["check_command"] }
    }
  },

  "$defs": {
    "policy": {
      "type": "string",
      "enum": ["hard", "soft", "none"],
      "description": "hard = merge on green CI + Reviewer approval; soft = merge after hold_hours unless vetoed; none = never auto-merge."
    },

    "on_rate_limit": {
      "type": "string",
      "enum": ["backoff", "fallback", "backoff_then_fallback", "quarantine"],
      "default": "backoff_then_fallback"
    },

    "on_capability_exceeded": {
      "type": "string",
      "enum": ["escalate", "fallback", "quarantine"],
      "default": "escalate"
    },

    "on_stall": {
      "type": "string",
      "enum": ["kill_retry_quarantine", "quarantine"],
      "default": "kill_retry_quarantine"
    },

    "model_ref": {
      "type": "object",
      "required": ["provider", "model"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1,
          "description": "Either a built-in provider (anthropic, openai, codex_cli) or a key declared under top-level `providers:`."
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "description": "Model identifier as understood by the resolved provider."
        }
      }
    },

    "custom_provider": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "openai_compatible",
            "anthropic_compatible",
            "claude_cli",
            "codex_cli"
          ]
        },
        "base_url": {
          "type": "string",
          "format": "uri",
          "description": "Required for openai_compatible / anthropic_compatible."
        },
        "api_key_env": {
          "type": "string",
          "description": "Env-var name (in .env) for the API key. Empty string = no key needed."
        },
        "binary_path": {
          "type": "string",
          "description": "For claude_cli / codex_cli: path to the binary, defaults to bare command name."
        },
        "vendor": {
          "type": "string",
          "enum": ["anthropic", "openai", "local", "operator-asserted"],
          "default": "operator-asserted",
          "description": "Vendor classification for the multi-vendor rule. claude_cli implies anthropic; codex_cli implies openai. For openai_compatible/anthropic_compatible custom endpoints, declare here so skynet doctor can enforce the rule."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "enum": ["openai_compatible", "anthropic_compatible"] } } },
          "then": { "required": ["type", "base_url"] }
        }
      ]
    },

    "agent_basic": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "primary": { "$ref": "#/$defs/model_ref" },
        "fallbacks": {
          "type": "array",
          "items": { "$ref": "#/$defs/model_ref" }
        },
        "prompt_extras": { "type": "string" },
        "tool_allowlist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "max_tokens_per_call": { "type": "integer", "minimum": 1000 },
        "timeout_seconds": { "type": "integer", "minimum": 10 },
        "max_retries": { "type": "integer", "minimum": 1, "maximum": 10 },
        "on_rate_limit": { "$ref": "#/$defs/on_rate_limit" },
        "on_capability_exceeded": { "$ref": "#/$defs/on_capability_exceeded" },
        "on_stall": { "$ref": "#/$defs/on_stall" }
      },
      "description": "Empty {} is valid — the role inherits everything from defaults. Required fields are enforced after defaults are merged in (handled by skynet doctor)."
    },

    "agent_researcher": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "primary": { "$ref": "#/$defs/model_ref" },
        "fallbacks": {
          "type": "array",
          "items": { "$ref": "#/$defs/model_ref" }
        },
        "prompt_extras": { "type": "string" },
        "tool_allowlist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "max_tokens_per_call": { "type": "integer", "minimum": 1000 },
        "timeout_seconds": { "type": "integer", "minimum": 10 },
        "max_retries": { "type": "integer", "minimum": 1, "maximum": 10 },
        "on_rate_limit": { "$ref": "#/$defs/on_rate_limit" },
        "on_capability_exceeded": { "$ref": "#/$defs/on_capability_exceeded" },
        "on_stall": { "$ref": "#/$defs/on_stall" },
        "schedule": {
          "type": "string",
          "description": "Cron expression. Required when enabled."
        },
        "max_per_day": {
          "type": "integer",
          "minimum": 1,
          "default": 5
        }
      },
      "if": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
      "then": { "required": ["schedule"] }
    },

    "agent_release": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "primary": { "$ref": "#/$defs/model_ref" },
        "fallbacks": {
          "type": "array",
          "items": { "$ref": "#/$defs/model_ref" }
        },
        "prompt_extras": { "type": "string" },
        "tool_allowlist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "max_tokens_per_call": { "type": "integer", "minimum": 1000 },
        "timeout_seconds": { "type": "integer", "minimum": 10 },
        "max_retries": { "type": "integer", "minimum": 1, "maximum": 10 },
        "on_rate_limit": { "$ref": "#/$defs/on_rate_limit" },
        "on_capability_exceeded": { "$ref": "#/$defs/on_capability_exceeded" },
        "on_stall": { "$ref": "#/$defs/on_stall" },
        "trigger": {
          "type": "string",
          "examples": ["milestone", "merge_count:5", "cron:0 0 * * 0"]
        }
      },
      "if": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
      "then": { "required": ["trigger"] }
    },

    "rig": {
      "type": "object",
      "description": "A hardware test rig. v1+ only.",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "server": { "$ref": "#/$defs/rig_node" },
        "camera": { "$ref": "#/$defs/rig_node" }
      }
    },

    "rig_node": {
      "type": "object",
      "description": "A single device within a rig.",
      "additionalProperties": false,
      "properties": {
        "ip": {
          "type": "string",
          "format": "ipv4"
        },
        "serial": {
          "type": "string",
          "description": "COM port (Windows) or device path (Linux/WSL)."
        },
        "smart_plug": {
          "type": "string",
          "description": "Smart-plug URI for power-cycle recovery, e.g. kasa://192.168.1.100"
        }
      }
    }
  }
}
