# Agentry — secrets template
# =============================================================================
#
# Copy this file to wherever `pipeline.local.toml`'s `host.env_file` points
# (default: ~/.agentry/.env on Linux/macOS, %USERPROFILE%/.agentry/.env on
# Windows) and fill in real values.
#
# Real .env files are NEVER committed. This template is committed as a
# reference for what the orchestrator and the LLM CLIs expect.
#
# The orchestrator loads .env once at startup. Spawned agent subprocesses
# inherit the environment, so the LLM CLIs (claude, codex, etc.) see these
# variables and can use them.

# -----------------------------------------------------------------------------
# Required for any setup
# -----------------------------------------------------------------------------

# GitHub fine-grained Personal Access Token.
# REQUIRED: the orchestrator runs as a Service (systemd / NSSM) and cannot
# rely on the Operator's interactive `gh auth` keyring.
# Generate at: https://github.com/settings/personal-access-tokens
# Scopes: contents (read+write), issues (read+write), pull_requests
# (read+write), metadata (read). Restrict the token to the target repos
# you operate on.
GITHUB_TOKEN=

# Discord webhook URL — agent lifecycle events (started, exited, stalled,
# timed-out) are posted here, batched every 60 seconds.
# Discord → Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Provider keys — fill in only the ones your role configs use
# -----------------------------------------------------------------------------
# These are read by the LLM CLI subprocesses, not by the framework. The
# framework only spawns the CLI; the CLI handles its own auth from the
# environment.

# Anthropic API key — used by `claude` CLI when it falls back from
# subscription auth to API auth, or if you point a custom wrapper at the API.
ANTHROPIC_API_KEY=

# OpenAI API key — used by `codex` CLI when API auth is needed, or by any
# OpenAI-compatible wrapper script.
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Optional — only fill in if a role rule file references them
# -----------------------------------------------------------------------------
# These are env vars role rule files might use. The framework doesn't read
# them. They're listed here so the Operator knows what to set up if their
# role files reference hardware, signing, networks, etc.

# SWUpdate bundle signing — used by a release.md rule file that signs
# Yocto SWU artifacts.
SWU_SIGNING_KEY_PATH=

# TP-Link Kasa cloud credentials — used by a tester.md rule file that
# power-cycles a hardware rig via Kasa cloud API.
KASA_USERNAME=
KASA_PASSWORD=

# Tailscale auth key — used by host setup if hardware rigs join via
# Tailscale mesh.
TAILSCALE_AUTH_KEY=

# Cloud VM SSH — used by host setup if a release.md rule file offloads
# Yocto builds to a remote VM.
GCP_VM_SSH_KEY_PATH=
