# Skynet Agentry — secrets template
# =============================================================================
#
# Copy this file to wherever `pipeline.local.toml`'s `host.env_file` points
# (default: ~/.skynet/.env on Linux/macOS, %USERPROFILE%/.skynet/.env on
# Windows) and fill in real values.
#
# Real .env files are NEVER committed.
# This template is committed as a reference for what the orchestrator
# expects to find.
#
# The orchestrator loads .env once at startup and passes only the keys
# each agent actually needs into restricted subprocess environments.
# Keys are never written to workspace files and never logged.

# -----------------------------------------------------------------------------
# REQUIRED for v0
# -----------------------------------------------------------------------------

# Anthropic API key — used by all Claude agents:
# Researcher, Architect, Implementer, Tester, PR Author.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI API key — used by the Reviewer agent.
# REQUIRED: the multi-vendor rule forbids implementer and reviewer
# being on the same vendor. Reviewer defaults to gpt-5 via OpenAI.
# Get one at https://platform.openai.com
OPENAI_API_KEY=

# GitHub fine-grained Personal Access Token.
# REQUIRED: the orchestrator runs as a Windows Service (or systemd
# unit) and cannot rely on the Operator's interactive `gh auth`
# keyring.
# Generate at: https://github.com/settings/personal-access-tokens
# Restrict the token to the target repos you'll operate on, with
# scopes: contents (read+write), issues (read+write), pull_requests
# (read+write), metadata (read).
GITHUB_TOKEN=

# Discord webhook URL — task lifecycle events and watchdog
# escalations are posted here, batched every 60 seconds.
# Discord → Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# OPTIONAL
# -----------------------------------------------------------------------------

# Codex CLI key — only if any agent.provider = "codex_cli".
CODEX_API_KEY=

# Local runtime key — only if any agent.provider = "local"
# (ollama, lm-studio). Often blank for local runtimes that
# don't require auth.
LOCAL_API_KEY=

# -----------------------------------------------------------------------------
# RESERVED — v1+
# -----------------------------------------------------------------------------
# Not used in v0. Leave blank. Documented so the v1 migration
# is obvious from this file alone.

# SWUpdate bundle signing — release engineering for Yocto targets.
# Path to a private key file readable only by the orchestrator user.
SWU_SIGNING_KEY_PATH=

# TP-Link Kasa cloud — smart-plug power-cycle recovery.
# Local-only Kasa control via tplink-smarthome-api may not require
# these; cloud control does.
KASA_USERNAME=
KASA_PASSWORD=

# Tailscale auth key — only if hardware rigs join via Tailscale mesh.
TAILSCALE_AUTH_KEY=

# GCP VM SSH — only if [gcp_vm].enabled = true in pipeline.local.toml
# and you're not using gcloud-managed SSH.
GCP_VM_SSH_KEY_PATH=
