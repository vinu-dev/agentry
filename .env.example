# Agentry - secrets template
# =============================================================================
#
# Copy this file to <target-repo>/agentry/.env and fill in real values.
# Real .env files are never committed. The orchestrator loads this file once at
# startup, and spawned agent subprocesses inherit the environment.

# -----------------------------------------------------------------------------
# GitHub auth
# -----------------------------------------------------------------------------

# Recommended for unattended operation. A fine-grained GitHub PAT should have:
# contents (read+write), issues (read+write), pull_requests (read+write), and
# metadata (read), restricted to the target repo.
#
# Alternatively, an authenticated `gh` CLI that can reach the target repo is
# enough for local foreground runs.
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------

# Optional Discord webhook. If unset, Agentry only writes local logs under:
#   <target-repo>/agentry/logs/<role>/
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# LLM provider API keys
# -----------------------------------------------------------------------------

# Optional fallback keys for CLIs or wrapper scripts. Many operators use
# subscription auth via `claude login` and `codex login` instead.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Role-specific optional environment
# -----------------------------------------------------------------------------

# These are examples used by some target role files. Leave blank unless your
# docs/ai/roles/*.md references them.
SWU_SIGNING_KEY_PATH=
KASA_USERNAME=
KASA_PASSWORD=
TAILSCALE_AUTH_KEY=
GCP_VM_SSH_KEY_PATH=
