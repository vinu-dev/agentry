# Agentry — secrets template
# =============================================================================
#
# Copy this file to wherever `pipeline.local.toml`'s `host.env_file` points
# (default: %USERPROFILE%\Agentry\.env on Windows, ~/.agentry/.env on Linux)
# and fill in real values.
#
# Real .env files are NEVER committed. This template is committed as a
# reference for what the orchestrator and the LLM CLIs expect.
#
# The orchestrator loads .env once at startup. Spawned agent subprocesses
# inherit the environment, so the LLM CLIs (claude, codex, etc.) see these
# variables and can use them.

# -----------------------------------------------------------------------------
# REQUIRED — minimum to operate against a real GitHub target
# -----------------------------------------------------------------------------

# GitHub fine-grained Personal Access Token.
# Required so the orchestrator can label issues, open PRs, etc., when running
# as a long-lived service (no interactive `gh auth login` keyring available).
# Generate at: https://github.com/settings/personal-access-tokens
# Scopes: contents (read+write), issues (read+write), pull_requests
# (read+write), metadata (read). Restrict the token to the target repos
# you operate on.
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL — notifications
# -----------------------------------------------------------------------------
# By default, Agentry just writes per-role logs to:
#   Windows: %USERPROFILE%\Agentry\logs\<role>\
#   Linux:   ~/.agentry/logs/<role>/
# That's enough for a single-machine setup — `tail -f` to watch live, or
# `agentry status` to see recent runs.
#
# Configure ONE of the channels below ONLY if you want push-style
# notifications (Discord ping when an agent stalls, etc.).

# Discord webhook URL — agent lifecycle events go here, batched 60s.
# Setup: Discord → Server Settings → Integrations → Webhooks → New Webhook.
# Leave blank to skip Discord entirely; the framework runs fine without it.
DISCORD_WEBHOOK_URL=

# (v0.2+ will add Telegram and email notifiers — leave blank for now.)

# -----------------------------------------------------------------------------
# OPTIONAL — LLM provider API keys
# -----------------------------------------------------------------------------
# These are read by the LLM CLI subprocesses, not by the framework itself.
# Most operators use subscription auth (`claude login` / `codex login`) and
# leave these blank. Fill in ONLY if you want API-key-based auth, e.g. as a
# fallback when the subscription rate-limits.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL — referenced by role rule files (not by the framework)
# -----------------------------------------------------------------------------
# Listed here so you know what to set up if a particular target's role rule
# files use them (e.g. for signing release artifacts, controlling hardware,
# or accessing remote infrastructure). Leave blank if your roles don't.

SWU_SIGNING_KEY_PATH=
KASA_USERNAME=
KASA_PASSWORD=
TAILSCALE_AUTH_KEY=
GCP_VM_SSH_KEY_PATH=
